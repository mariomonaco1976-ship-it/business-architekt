---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Business Architekt – strukturelle Einordnung für klare Entscheidungen.' } = Astro.props;

const navItems = [
  { href: '/', label: 'Start' },
  { href: '/so-funktioniert-es', label: 'Business-System-Fit' },
  { href: '/warum', label: 'Business Architekt' },
  { href: '/faq', label: 'FAQ' },
  { href: '/sparring', label: 'Sparring' },
];

const normalizePath = (path: string) => {
  if (path === '/') return path;
  return path.replace(/\/+$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} – Business Architekt</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/ba_logo_baum.svg?v=2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --primary: #100746;
        --primary-dark: #0a0430;
        --gold: #97832C;
        --bg: #F7F6F2;
        --text: #1A1A1A;
        --divider: #E6E4DC;
        --card-bg: #ffffff;
        --font-head: 'Crimson Pro', Georgia, serif;
        --font-body: 'Source Sans 3', 'IBM Plex Sans', system-ui, sans-serif;
        --max-w: 1200px;
        --section-gap: clamp(3rem, 6vw, 5rem);
      }

      body {
        font-family: var(--font-body);
        font-size: clamp(16px, 1.1vw + 12px, 18px);
        line-height: 1.65;
        color: var(--text);
        background-color: var(--bg);
        background-image:
          linear-gradient(rgba(16,7,70,0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(16,7,70,0.045) 1px, transparent 1px);
        background-size: 28px 28px;
      }

      h1 {
        font-family: var(--font-head);
        font-size: clamp(34px, 4.5vw, 52px);
        font-weight: 700;
        line-height: 1.12;
        color: var(--primary);
        letter-spacing: -0.02em;
      }
      h2 {
        font-family: var(--font-head);
        font-size: clamp(26px, 3vw, 36px);
        font-weight: 600;
        line-height: 1.2;
        color: var(--primary);
        letter-spacing: -0.01em;
        margin-top: 2.2rem;
      }
      h3 {
        font-family: var(--font-head);
        font-size: clamp(20px, 1.9vw, 26px);
        font-weight: 600;
        line-height: 1.28;
        color: var(--primary);
        margin-top: 1.6rem;
      }

      p { max-width: 74ch; margin-top: 0.65rem; }
      ul, ol { margin-top: 0.85rem; margin-left: 1.25rem; }
      li { margin: 0.35rem 0; }
      a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }
      a:hover { color: var(--primary); }

      .container {
        width: 100%;
        max-width: var(--max-w);
        margin-inline: auto;
        padding-inline: clamp(1.25rem, 5vw, 3rem);
      }

      .section { padding-block: var(--section-gap); }
      .divider-line { border: none; border-top: 1px solid var(--divider); }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(247,246,242,0.92);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--divider);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-block: 1.1rem;
      }
      .logo {
        font-family: var(--font-head);
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        letter-spacing: 0.02em;
      }
      .logo span {
        display: block;
        font-size: 0.72rem;
        font-weight: 400;
        color: var(--gold);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .header-nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem 1rem;
        flex-wrap: wrap;
      }
      .header-nav a {
        font-size: 0.8rem;
        text-decoration: none;
        color: var(--primary);
        opacity: 0.75;
        white-space: nowrap;
      }
      .header-nav a:hover { opacity: 1; text-decoration: underline; text-underline-offset: 4px; }
      .header-nav a.active { opacity: 1; text-decoration: underline; text-underline-offset: 4px; font-weight: 600; }
      .nav-cta {
        display: inline-block;
        background: var(--primary);
        color: #fff;
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        padding: 0.55rem 1.25rem;
        border: 1px solid var(--gold);
        border-radius: 8px;
        transition: background 0.2s;
      }
      .nav-cta:hover { background: var(--primary-dark); color: #fff; }

      /* Hamburger button */
      .menu-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }
      .menu-toggle span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--primary);
        border-radius: 2px;
      }

      .hero {
        padding-block: clamp(3.5rem, 7vw, 5.5rem);
      }
      .hero .section-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.6rem;
      }
      .hero-intro {
        font-size: clamp(17px, 1.4vw, 20px);
        line-height: 1.62;
        color: #3a3830;
        margin-top: 1.05rem;
      }

      .content-card {
        background: var(--card-bg);
        border: 1px solid var(--divider);
        padding: clamp(1.2rem, 2.5vw, 2rem);
      }
      .checkmarks {
        margin-top: 1.4rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        color: #6a6860;
        font-size: 0.88rem;
      }
      .checkmarks span::before {
        content: '✓  ';
        color: var(--gold);
        font-weight: 700;
      }

      .site-footer {
        background: var(--primary);
        color: rgba(247,246,242,0.5);
        padding-block: 2.2rem;
        font-size: 0.83rem;
        margin-top: 2rem;
      }
      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .footer-links { display: flex; gap: 1.2rem; }
      .footer-links a { color: rgba(247,246,242,0.65); text-decoration: none; }
      .footer-links a:hover { color: rgba(247,246,242,0.9); }

      @media (max-width: 900px) {
        .header-inner { position: relative; }
        .menu-toggle { display: flex; }
        .header-nav {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: rgba(247,246,242,0.97);
          backdrop-filter: blur(8px);
          border-bottom: 1px solid var(--divider);
          flex-direction: column;
          align-items: flex-start;
          padding: 1rem clamp(1.25rem, 5vw, 3rem);
          gap: 0.75rem;
          z-index: 99;
        }
        .header-nav.open { display: flex; }
        .nav-cta { display: none; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="header-inner">
          <a href="/" class="logo">
            <img src="/ba_logo_header.svg?v=2" alt="Business Architekt" style="height: 40px; width: auto;">
          </a>
          <nav id="main-nav" class="header-nav" aria-label="Seitennavigation">
            {navItems.map((item) => {
              const isActive = currentPath === normalizePath(item.href);
              return (
                <a href={item.href} class:list={[{ active: isActive }]}>{item.label}</a>
              );
            })}
          </nav>
          <button id="menu-toggle" class="menu-toggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="main-nav">
            <span></span>
            <span></span>
            <span></span>
          </button>
          <a href="https://bot.mariowittmer.de/business-system-fit-v-3-4-1-r2vcd4e" class="nav-cta" target="_blank" rel="noopener noreferrer">Dein nächster Schritt</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div>© 2026 · Business Architekt</div>
          <nav class="footer-links">
            <a href="/impressum">Impressum</a>
            <a href="/datenschutz">Datenschutz</a>
            <a href="/agb">AGB</a>
          </nav>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const nav = document.getElementById('main-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const isOpen = nav.classList.contains('open');
          nav.classList.toggle('open', !isOpen);
          toggle.setAttribute('aria-expanded', String(!isOpen));
          toggle.setAttribute('aria-label', isOpen ? 'Menü öffnen' : 'Menü schließen');
        });
        nav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            nav.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
            toggle.setAttribute('aria-label', 'Menü öffnen');
          });
        });
      }
    </script>
  </body>
</html>