---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sparring">
  <section class="mx-auto w-full max-w-4xl px-6 py-20 md:py-28">
    <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">Sparring</h1>
    <p class="mt-6 text-lg leading-relaxed text-slate-600">
      Platzhaltertext: Diese Seite beschreibt später Format, Rhythmus und Ergebnisse eines Sparrings für Entscheiderinnen
      und Entscheider.
    </p>
  </section>

  <section class="border-t border-slate-200">
    <div class="mx-auto w-full max-w-4xl px-6 py-16">
      <h2 class="text-2xl font-semibold tracking-tight">Was Sie erwarten können</h2>
      <p class="mt-4 text-slate-600">
        Platzhaltertext: Ein verlässlicher Rahmen für Reflexion, Schärfung von Optionen und konkrete nächste Schritte.
      </p>
      <a href="/so-funktioniert-es" class="mt-6 inline-flex text-sm font-medium text-slate-900 underline underline-offset-4">
        Ablauf lesen
      </a>
    </div>
  </section>
</BaseLayout>
