---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'Für wen ist Business Architekt geeignet?',
    a: 'Business Architekt richtet sich an Führungskräfte und Gründerinnen in mittleren und größeren Unternehmen, die in komplexen, oft unklaren Entscheidungssituationen strukturiert vorankommen wollen – allein oder mit einem kleinen Führungsteam.',
  },
  {
    q: 'Wie lange dauert ein typischer Prozess?',
    a: 'Ein erster Orientierungsrahmen entsteht typischerweise in einem bis zwei Gesprächen. Komplexere Vorhaben werden in mehreren Sitzungen über vier bis acht Wochen begleitet – abhängig von Situation, Tempo und verfügbarer Zeit.',
  },
  {
    q: 'Wie unterscheidet sich das von klassischer Beratung?',
    a: 'Business Architekt liefert keine fertige Lösung und kein Umsetzungsteam. Stattdessen schärft der Prozess die Entscheidungsfähigkeit der Führungskraft selbst – durch Struktur, Reflexion und klare nächste Schritte. Die Verantwortung bleibt, wo sie hingehört: bei Ihnen.',
  },
];
---

<BaseLayout title="FAQ">
  <section class="mx-auto w-full max-w-4xl px-6 py-20 md:py-28">
    <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">FAQ</h1>
    <p class="mt-6 text-lg leading-relaxed text-slate-600">
      Antworten auf häufige Fragen zu Zielgruppe, Ablauf und dem Unterschied zur klassischen Unternehmensberatung.
    </p>

    <div class="mt-12 divide-y divide-slate-200 border-y border-slate-200">
      {faqs.map((faq) => (
        <article class="py-6">
          <h2 class="text-xl font-semibold tracking-tight">{faq.q}</h2>
          <p class="mt-3 text-slate-600">{faq.a}</p>
        </article>
      ))}
    </div>

    <a href="/" class="mt-10 inline-flex text-sm font-medium text-slate-900 underline underline-offset-4">
      Zur Startseite
    </a>
  </section>
</BaseLayout>
