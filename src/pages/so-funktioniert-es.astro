  <style>
    .hero-tight-bottom {
      padding-bottom: clamp(1.5rem, 3vw, 2.25rem) !important;
    }

    .section-tight-top {
      padding-top: clamp(1.5rem, 3vw, 2.25rem) !important;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      margin-top: 0;
      align-items: start;
    }

    .cards-grid .content-card > h2:first-child {
      margin-top: 0 !important;
    }

    .time-line {
      display: inline-block;
      margin-top: 0.2rem;
      white-space: nowrap;
    }

    .content-card {
      background: var(--card-bg);
      border: 1px solid var(--divider);
      border-radius: 8px;
      padding: clamp(1.75rem, 4vw, 2.5rem);
    }

    .card-step-match {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      min-height: 0;
    }

    .card-dark-step {
      background: var(--primary);
      border-color: var(--primary);
      color: #F7F6F2;
    }

    .card-dark-step h2 {
      color: #F7F6F2;
    }

    .card-dark-step p,
    .card-dark-step ul,
    .card-dark-step li {
      color: #d9d6eb;
    }

    .card-cta {
      background: linear-gradient(135deg, rgba(16, 7, 70, 0.02) 0%, rgba(151, 131, 44, 0.04) 100%);
    }

    .card-report {
      max-height: none;
      overflow: visible;
    }

    .price-card {
      background: var(--card-bg);
      border: 1px solid var(--divider);
      border-radius: 8px;
      padding: clamp(1.75rem, 4vw, 2.5rem);
    }

    .price-card-highlight {
      background: var(--primary);
      border-color: var(--primary);
      color: #F7F6F2;
    }

    .price-card-highlight h3 {
      color: #F7F6F2;
    }

    .price-tag {
      font-family: var(--font-head);
      font-size: clamp(36px, 4vw, 52px);
      font-weight: 700;
      line-height: 1;
      margin-block: 0.75rem;
    }

    .price-card-highlight .price-tag {
      color: #d4c86a;
    }

    .price-label {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.25rem;
    }

    .price-card-highlight .price-label {
      color: #d4c86a;
    }

    .price-card p {
      font-size: 0.9rem;
      line-height: 1.6;
      max-width: none;
    }

    .price-card-highlight p {
      color: #b8b5d0;
    }

    .price-card-highlight .checkmark-item {
      color: #9995b0;
    }

    .checkmark-item::before {
      content: '✓  ';
      color: var(--gold);
      font-weight: 700;
    }

    .price-card-highlight .checkmark-item::before {
      color: #d4c86a;
    }

    @media (max-width: 900px) {
      .cards-grid {
        grid-template-columns: 1fr;
      }

      .card-step-match {
        height: auto !important;
      }
    }
  </style>

  <script is:inline>
    const syncStepCardHeights = () => {
      const referenceCard = document.querySelector('.card-step-reference');
      const matchingCards = document.querySelectorAll('.card-step-match');
      if (!referenceCard || matchingCards.length === 0) return;

      matchingCards.forEach((card) => {
        card.style.height = 'auto';
      });

      if (window.innerWidth <= 900) return;

      const referenceHeight = Math.ceil(referenceCard.getBoundingClientRect().height);
      matchingCards.forEach((card) => {
        card.style.height = `${referenceHeight}px`;
      });
    };

    window.addEventListener('load', syncStepCardHeights);
    window.addEventListener('resize', syncStepCardHeights);
    window.addEventListener('pageshow', syncStepCardHeights);
    requestAnimationFrame(syncStepCardHeights);
    setTimeout(syncStepCardHeights, 60);
  </script>
</PremiumSubpageLayout>
