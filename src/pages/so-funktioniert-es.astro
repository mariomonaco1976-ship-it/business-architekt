---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    title: '1. Standort bestimmen',
    text: 'Platzhaltertext: Gemeinsamer Blick auf Zielbild, Randbedingungen und vorhandene Informationen.',
  },
  {
    title: '2. Optionen strukturieren',
    text: 'Platzhaltertext: Mögliche Wege werden geordnet, bewertet und auf Entscheidbarkeit reduziert.',
  },
  {
    title: '3. Nächsten Schritt festlegen',
    text: 'Platzhaltertext: Ein umsetzbarer Plan mit klaren Verantwortungen und realistischer Taktung.',
  },
];
---

<BaseLayout title="Ablauf">
  <section class="mx-auto w-full max-w-4xl px-6 py-20 md:py-28">
    <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">So funktioniert es</h1>
    <p class="mt-6 text-lg leading-relaxed text-slate-600">
      Platzhaltertext: Auf dieser Seite wird später der Ablauf in wenigen, nachvollziehbaren Schritten erklärt.
    </p>

    <ol class="mt-12 space-y-8">
      {steps.map((step) => (
        <li class="border-l border-slate-300 pl-6">
          <h2 class="text-xl font-semibold tracking-tight">{step.title}</h2>
          <p class="mt-3 text-slate-600">{step.text}</p>
        </li>
      ))}
    </ol>

    <a href="/sparring" class="mt-12 inline-flex rounded-md bg-slate-900 px-5 py-3 text-sm font-medium text-white">
      Sparring ansehen
    </a>
  </section>
</BaseLayout>
