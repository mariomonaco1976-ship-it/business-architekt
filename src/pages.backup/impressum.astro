---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum">
  <section class="mx-auto w-full max-w-6xl px-6 py-20 md:py-28">
    <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">Impressum</h1>
    
    <div class="mt-12 max-w-3xl space-y-8 text-slate-600">
      <section>
        <h2 class="text-2xl font-semibold text-slate-900">Angaben gemäß § 5 TMG</h2>
        <p class="mt-4">
          Mario Wittmer (Business Architekt)<br/>
          c/o Baumgartner<br/>
          Kurbelwiesgasse 3<br/>
          80939 München<br/>
          Deutschland
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-slate-900">Kontakt</h2>
        <p class="mt-4">
          E-Mail: kontakt@mariowittmer.de
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-slate-900">Rechtsform</h2>
        <p class="mt-4">
          Einzelunternehmer (Kleinunternehmer)
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-slate-900">Umsatzsteuer</h2>
        <p class="mt-4">
          Als Kleinunternehmer im Sinne von § 19 UStG wird keine Umsatzsteuer berechnet und ausgewiesen.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-slate-900">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
        <p class="mt-4">
          Mario Wittmer<br/>
          c/o Baumgartner<br/>
          Kurbelwiesgasse 3<br/>
          80939 München
        </p>
      </section>

      <section class="mt-12 border-t border-slate-200 pt-8">
        <p class="text-sm text-slate-500">
          <a href="/datenschutz" class="text-slate-900 hover:underline">Datenschutzerklärung</a> | <a href="/agb" class="text-slate-900 hover:underline">AGB</a>
        </p>
      </section>
    </div>
  </section>
</BaseLayout>
