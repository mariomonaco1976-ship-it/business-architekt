---
// Final Design: Elegant / Premium Concept
---

<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Business Architekt – Human-System-Fit</title>
<link rel="icon" type="image/svg+xml" href="/ba_logo_baum.svg?v=2">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<style is:global>
  /* ============================================================
     RESET & BASE
  ============================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary:       #100746;
    --primary-dark:  #0a0430;
    --gold:          #97832C;
    --signal:        #FF5757;
    --bg:            #F7F6F2;
    --text:          #1A1A1A;
    --divider:       #E6E4DC;
    --card-bg:       #ffffff;
    --card-alt:      #2A265C;
    --card-alt-text: #F7F6F2;
    --font-head:     'Crimson Pro', Georgia, serif;
    --font-body:     'Source Sans 3', 'IBM Plex Sans', system-ui, sans-serif;
    --max-w:         1200px;
    --gap:           clamp(1rem, 2.5vw, 1.75rem);
    --section-gap:   clamp(4rem, 8vw, 7rem);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.1vw + 12px, 18px);
    line-height: 1.65;
    color: var(--text);
    background-color: var(--bg);
    background-image:
      linear-gradient(rgba(16,7,70,0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16,7,70,0.045) 1px, transparent 1px);
    background-size: 28px 28px;
    min-height: 100vh;
  }

  /* ============================================================
     TYPOGRAPHY
  ============================================================ */
  h1 {
    font-family: var(--font-head);
    font-size: clamp(38px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.12;
    color: var(--primary);
    letter-spacing: -0.02em;
  }
  h2 {
    font-family: var(--font-head);
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 600;
    line-height: 1.2;
    color: var(--primary);
    letter-spacing: -0.01em;
  }
  h3 {
    font-family: var(--font-head);
    font-size: clamp(18px, 1.8vw, 24px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--primary);
  }
  p { max-width: 68ch; }
  small, .meta {
    font-size: clamp(13px, 0.9vw + 10px, 15px);
    color: #6B6860;
    line-height: 1.5;
  }
  a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }
  a:hover { color: var(--primary); }

  /* ============================================================
     LAYOUT HELPERS
  ============================================================ */
  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  .section { padding-block: var(--section-gap); }

  .divider-line {
    border: none;
    border-top: 1px solid var(--divider);
    margin-block: 0;
  }

  /* ============================================================
     HEADER / NAV
  ============================================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(247,246,242,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--divider);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
  }
  .logo {
    font-family: var(--font-head);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
    letter-spacing: 0.02em;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .logo span {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--gold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .header-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 1rem;
    flex-wrap: wrap;
  }
  .header-nav a {
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--primary);
    opacity: 0.75;
    white-space: nowrap;
  }
  .header-nav a:hover { opacity: 1; text-decoration: underline; text-underline-offset: 4px; }
  .nav-cta {
    display: inline-block;
    background: #fff;
    color: var(--gold);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.55rem 1.25rem;
    border: 1px solid var(--gold);
    border-radius: 8px;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: #f7f3e6; color: var(--gold); }

  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    padding-block: clamp(5rem, 10vw, 9rem);
    border-bottom: 1px solid var(--divider);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 820px;
  }
  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .hero h1 {
    max-width: none;
    line-height: 1.02;
    text-wrap: unset;
  }
  .hero-line {
    display: block;
    white-space: nowrap;
  }
  .hero-sub {
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: #3a3830;
    max-width: 72ch;
    text-wrap: pretty;
  }
  .hero-sub-line,
  .hero-sub-end {
    display: block;
  }
  .hero-sub-end {
    color: var(--primary);
    font-weight: 600;
  }
  .hero-sub strong { color: var(--primary); font-weight: 600; }
  .hero-levers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap);
    margin-top: 0.5rem;
  }
  .hero-lever {
    border-left: 2px solid var(--gold);
    padding-left: 1rem;
  }
  .hero-lever strong {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 0.25rem;
  }
  .hero-lever p {
    font-size: 0.88rem;
    color: #5a5750;
    line-height: 1.5;
    max-width: none;
  }
  .hero-thesis {
    background: var(--primary);
    color: #F7F6F2;
    padding: 1.5rem 1.75rem;
    max-width: 640px;
  }
  .hero-thesis p {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.65;
    max-width: none;
  }
  .hero-thesis p strong { color: #d4c86a; }
  .hero-actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .btn-primary {
    display: inline-block;
    background: var(--primary);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.85rem 2rem;
    border: 1px solid var(--gold);
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--primary-dark); color: #fff; }
  .hero-note { font-size: 0.83rem; color: #7a7870; }

  /* ============================================================
     SYMPTOM SECTION
  ============================================================ */
  .symptom-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--gap);
    margin-top: 2.5rem;
  }
  .symptom-card {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    padding: 2rem 1.75rem;
  }
  .symptom-card h3 { margin-bottom: 0.75rem; }
  .symptom-card .desc { font-size: 0.93rem; color: #4a4840; margin-bottom: 1.25rem; max-width: none; }
  .symptom-card ul { list-style: none; padding: 0; }
  .symptom-card ul li {
    font-size: 0.9rem;
    padding: 0.5rem 0;
    border-top: 1px solid var(--divider);
    color: #3a3830;
    padding-left: 1rem;
    position: relative;
  }
  .symptom-card ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--signal);
    font-size: 0.75rem;
  }

  /* ============================================================
     ZAHLENBLOCK
  ============================================================ */
  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--gap);
    margin-top: 2.5rem;
  }
  .number-card {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    padding: 2rem 1.75rem;
  }
  .number-card:nth-child(1) { grid-column: span 5; }
  .number-card:nth-child(2) { grid-column: span 7; }
  .number-card:nth-child(3) { grid-column: span 4; }
  .number-card:nth-child(4) { grid-column: span 8; }
  .number-big {
    font-family: var(--font-head);
    font-size: clamp(42px, 5vw, 64px);
    font-weight: 700;
    color: var(--primary);
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .number-card p {
    font-size: 0.95rem;
    color: #3a3830;
    line-height: 1.55;
    max-width: 90%;
    margin-bottom: 1rem;
  }
  .number-source {
    font-size: 0.78rem;
    color: #8a8880;
    border-top: 1px solid var(--divider);
    padding-top: 0.75rem;
  }
  .number-source a { color: #8a8880; font-size: inherit; }
  .number-card.card-dark {
    background: var(--card-alt);
    border-color: var(--card-alt);
    color: var(--card-alt-text);
  }
  .number-card.card-dark .number-big { color: #d4c86a; }
  .number-card.card-dark p { color: #ccc9e0; }
  .number-card.card-dark .number-source { color: #9995b0; border-color: rgba(255,255,255,0.1); }
  .number-card.card-dark .number-source a { color: #9995b0; }

  /* ============================================================
     SYSTEM VISUALISIERUNG
  ============================================================ */
  .system-section { background: var(--primary); color: #F7F6F2; }
  .system-section h2 { color: #F7F6F2; }
  .system-section .section-intro { color: #b8b5d0; max-width: 58ch; margin-top: 0.75rem; }

  .orbit-wrapper {
    position: relative;
    width: min(560px, 90vw);
    height: min(560px, 90vw);
    margin: 3.5rem auto 0;
  }
  .orbit-center {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 120px; height: 120px;
    border-radius: 50%;
    background: rgba(212,200,106,0.12);
    border: 2px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: var(--font-head);
    font-size: 1.05rem;
    font-weight: 700;
    color: #d4c86a;
    line-height: 1.3;
    z-index: 2;
    cursor: pointer;
    transition: all 0.35s ease;
  }
  .orbit-center:hover {
    width: 180px;
    height: 180px;
    background: rgba(16,7,70,0.95);
    border-color: #d4c86a;
    font-size: 0.82rem;
    line-height: 1.45;
  }
  .orbit-center .center-main { transition: opacity 0.2s; }
  .orbit-center:hover .center-main { opacity: 0; }
  .orbit-center .center-hover {
    position: absolute;
    opacity: 0;
    padding: 1.2rem;
    transition: opacity 0.2s 0.15s;
    font-weight: 400;
  }
  .orbit-center:hover .center-hover { opacity: 1; }
  .orbit-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 430px; height: 430px;
    max-width: 78vw; max-height: 78vw;
    border-radius: 50%;
    border: 1px solid rgba(212,200,106,0.2);
  }

  /* Six orbit cards positioned at clock positions */
  .orbit-card {
    position: absolute;
    width: 130px;
    background: rgba(42,38,92,0.9);
    border: 1px solid rgba(212,200,106,0.25);
    padding: 0.85rem 0.9rem;
    font-size: 0.8rem;
    line-height: 1.45;
    transition: all 0.28s ease;
    cursor: default;
    overflow: hidden;
    z-index: 3;
  }
  .orbit-card strong {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    color: #d4c86a;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }
  .orbit-card .card-desc {
    display: none;
    font-size: 0.75rem;
    color: #9995b0;
    margin-top: 0.4rem;
    line-height: 1.5;
  }
  .orbit-card:hover {
    width: 155px;
    background: rgba(16,7,70,0.98);
    border-color: var(--gold);
    z-index: 10;
  }
  .orbit-card:hover .card-desc { display: block; }

  /* Positions: top, top-right, bottom-right, bottom, bottom-left, top-left */
  /* Using percentage positioning relative to orbit-wrapper */
  .orbit-card:nth-child(3) { /* top 12 o'clock */
    top: 2%; left: 50%; transform: translateX(-50%);
  }
  .orbit-card:nth-child(4) { /* 2 o'clock */
    top: 18%; right: 0%; transform: translateX(20%);
  }
  .orbit-card:nth-child(5) { /* 4 o'clock */
    bottom: 18%; right: 0%; transform: translateX(20%);
  }
  .orbit-card:nth-child(6) { /* 6 o'clock */
    bottom: 2%; left: 50%; transform: translateX(-50%);
  }
  .orbit-card:nth-child(7) { /* 8 o'clock */
    bottom: 18%; left: 0%; transform: translateX(-20%);
  }
  .orbit-card:nth-child(8) { /* 10 o'clock */
    top: 18%; left: 0%; transform: translateX(-20%);
  }

  .system-note {
    text-align: center;
    margin-top: 2.5rem;
    font-size: 0.85rem;
    color: rgba(184,181,208,0.7);
    font-style: italic;
  }

  /* ============================================================
     ERGEBNISBEREICH
  ============================================================ */
  .result-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--gap);
    margin-top: 2.5rem;
  }
  .result-card {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    padding: 2rem 1.75rem;
    border-top: 3px solid var(--primary);
  }
  .result-card h3 { margin-bottom: 0.75rem; }
  .result-card p { font-size: 0.93rem; color: #4a4840; line-height: 1.6; max-width: none; }
  .result-thesis {
    margin: var(--gap) auto 0;
    max-width: 860px;
    text-align: center;
  }
  .result-thesis p {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.65;
    max-width: none;
    margin-top: 0;
  }
  .result-thesis p strong { color: #d4c86a; }
  .result-thesis-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d4c86a;
    margin-bottom: 0.4rem;
  }
  .result-thesis strong {
    display: inline-block;
    font-size: clamp(22px, 2.2vw, 30px);
    margin-bottom: 0.35rem;
  }

  /* KONSEQUENZ */
  .consequence-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap);
    margin-top: 2.5rem;
  }
  .consequence-col {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    padding: 2rem 1.75rem;
  }
  .consequence-col.col-before { border-top: 3px solid var(--signal); }
  .consequence-col.col-after  { border-top: 3px solid var(--gold); }
  .consequence-col h3 { margin-bottom: 1.25rem; }
  .consequence-col ul { list-style: none; padding: 0; }
  .consequence-col ul li {
    font-size: 0.93rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--divider);
    color: #3a3830;
    padding-left: 1.25rem;
    position: relative;
  }
  .col-before ul li::before { content: '×'; position: absolute; left: 0; color: var(--signal); font-weight: 700; }
  .col-after  ul li::before { content: '→'; position: absolute; left: 0; color: var(--gold); font-weight: 700; }

  /* ============================================================
     PRICING / CTA
  ============================================================ */
  .pricing-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap);
    margin-top: 2.5rem;
  }
  .price-card {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    padding: 2rem 1.75rem;
  }
  .price-card.price-active {
    background: var(--primary);
    border-color: var(--primary);
    color: #F7F6F2;
  }
  .price-card.price-active h3 { color: #F7F6F2; }
  .price-tag {
    font-family: var(--font-head);
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 700;
    line-height: 1;
    margin-block: 0.75rem;
  }
  .price-card.price-active .price-tag { color: #d4c86a; }
  .price-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }
  .price-card.price-active .price-label { color: #d4c86a; }
  .price-card p { font-size: 0.9rem; line-height: 1.6; max-width: none; }
  .price-card.price-active p { color: #b8b5d0; }
  .checkmarks {
    margin-top: 1.25rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .checkmark-item {
    font-size: 0.83rem;
    color: #6a6860;
  }
  .price-card.price-active .checkmark-item { color: #9995b0; }
  .checkmark-item::before { content: '✓  '; color: var(--gold); font-weight: 700; }
  .price-card.price-active .checkmark-item::before { color: #d4c86a; }

  /* ============================================================
     ABSCHLUSS / BOT
  ============================================================ */
  .closing-section {
    border-top: 1px solid var(--divider);
  }
  .closing-inner {
    max-width: 700px;
  }
  .closing-inner h2 { margin-bottom: 1rem; }
  .closing-inner p { color: #4a4840; margin-bottom: 2rem; }
  .bot-placeholder {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aaa9a0;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 2.5rem;
  }

  /* ============================================================
     FOOTER
  ============================================================ */
  .site-footer {
    background: var(--primary);
    color: rgba(247,246,242,0.5);
    padding-block: 2.5rem;
    font-size: 0.83rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-logo {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: rgba(247,246,242,0.8);
  }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { color: rgba(247,246,242,0.45); text-decoration: none; font-size: 0.8rem; }
  .footer-links a:hover { color: rgba(247,246,242,0.8); }

  /* ============================================================
     SECTION HEADER
  ============================================================ */
  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
  }
  .section-intro {
    font-size: clamp(15px, 1.15vw, 17px);
    color: #4a4840;
    max-width: 56ch;
    margin-top: 0.5rem;
    line-height: 1.65;
  }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 900px) {
    .numbers-grid { grid-template-columns: 1fr 1fr; }
    .number-card:nth-child(n) { grid-column: span 1; }
    .consequence-grid { grid-template-columns: 1fr; }
    .pricing-block { grid-template-columns: 1fr; }
    .orbit-wrapper { width: min(420px, 90vw); height: min(420px, 90vw); }
    .orbit-ring { width: 320px; height: 320px; }
    .orbit-card { width: 110px; font-size: 0.75rem; padding: 0.7rem 0.75rem; }
    .orbit-card:hover { width: 130px; }
    .orbit-center { width: 96px; height: 96px; font-size: 0.88rem; }
    .orbit-center:hover { width: 145px; height: 145px; font-size: 0.72rem; }
  }

  @media (max-width: 640px) {
    .header-inner { flex-direction: column; align-items: flex-start; }
    .header-nav { justify-content: flex-start; }
    .hero-line { white-space: normal; }
    .hero-levers { grid-template-columns: 1fr; }
    .numbers-grid { grid-template-columns: 1fr; }
    .number-card:nth-child(n) { grid-column: span 1; }
    .orbit-wrapper { width: 92vw; height: 92vw; }
    .orbit-ring { width: 70vw; height: 70vw; }
    .orbit-card { width: 90px; font-size: 0.68rem; padding: 0.6rem; }
    .orbit-card:hover { width: 108px; }
    .orbit-center { width: 76px; height: 76px; font-size: 0.78rem; }
    .orbit-center:hover { width: 120px; height: 120px; font-size: 0.62rem; }
    .orbit-center .center-hover { padding: 0.8rem; }
    .footer-inner { flex-direction: column; }
  }
</style>
</head>
<body>

<!-- ============================================================
     HEADER
============================================================ -->
<header class="site-header">
  <div class="container">
