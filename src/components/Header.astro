---
const navItems = [
  { href: '/', label: 'Start' },
  { href: '/warum', label: 'Warum' },
  { href: '/so-funktioniert-es', label: 'Ablauf' },
  { href: '/sparring', label: 'Sparring' },
  { href: '/faq', label: 'FAQ' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-200">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-4 px-6 py-6 md:flex-row md:items-center md:justify-between">
    <a href="/" class="text-xl font-semibold tracking-tight text-slate-900">Business Architekt</a>
    <nav aria-label="Hauptnavigation" class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600">
      {navItems.map((item) => {
        const isActive = currentPath === item.href;
        return (
          <a
            href={item.href}
            class:list={[
              'transition-none',
              isActive ? 'font-medium text-slate-900 underline underline-offset-4' : 'hover:text-slate-900',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
